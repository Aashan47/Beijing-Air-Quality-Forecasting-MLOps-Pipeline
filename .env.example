# OpenAQ API (free, register at https://explore.openaq.org)
OPENAQ_API_KEY=your-openaq-api-key-here

# Weather: uses Open-Meteo (free, no API key needed) — no config required

# AWS
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_DEFAULT_REGION=us-east-1

# S3
S3_BUCKET=air-quality-mlops-data

# SageMaker
SAGEMAKER_ROLE_ARN=arn:aws:iam::role/SageMakerExecutionRole
